# Citadel Ops — environment
# Postgres runs on 5433 via docker-compose (see docker-compose.yml).
DATABASE_URL=postgres://citadel:citadel@localhost:5433/citadel

# Redis backplane (§HORIZON) — event fan-out + distributed rate limits across instances.
# REQUIRED in production (00.env-check.ts); without it the app falls back to in-process
# single-instance behaviour in dev. docker-compose runs Redis on 6380.
REDIS_URL=redis://localhost:6380

# 32+ char secret for nuxt-auth-utils sessions. REQUIRED in production — the app
# refuses to boot with an empty/short value (server/plugins/00.env-check.ts).
NUXT_SESSION_PASSWORD=change-me-to-a-long-random-string-min-32-chars

# Public base URL (used in invitation emails for the accept link).
NUXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (invitations). If SMTP_HOST is unset, mail is logged, not sent. ---
# Works with any SMTP provider (Resend/SES/Postmark) or local Mailpit (port 1025).
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# MAIL_FROM="Citadel Ops <no-reply@citadel.test>"

# --- Echelon telemetry (all optional; no-op when unset) ---
# Sentry error tracking (server + client).
# SENTRY_DSN=
# NUXT_PUBLIC_SENTRY_DSN=
# Protect GET /metrics (Prometheus) with a bearer token. Open if unset.
# METRICS_TOKEN=

# --- Auth ---
# Failed logins per ip+email before a 15-min 429 lockout (default 10).
# LOGIN_MAX_ATTEMPTS=10

# --- Seed safety ---
# `npm run db:seed` WIPES the demo org + installs demo credentials. It refuses to
# run when NODE_ENV=production unless you explicitly set:
# CITADEL_ALLOW_SEED=true
